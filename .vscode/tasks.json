{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend (Angular)",
      "type": "npm",
      "script": "start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Generating browser application bundles|Building...",
          "endsPattern": "Application bundle generation complete|Compiled successfully"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "fullstack"
      }
    },
    {
      "label": "Start Backend (FastAPI)",
      "type": "shell",
      "command": "conda activate cv-architect; poetry run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Will watch for changes in these directories:|Started server process",
          "endsPattern": "Uvicorn running on|Application startup complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "fullstack"
      }
    },
    {
      "label": "Start Full Stack",
      "dependsOn": ["Start Backend (FastAPI)", "Start Frontend (Angular)"],
      "dependsOrder": "parallel"
    }
  ]
}
