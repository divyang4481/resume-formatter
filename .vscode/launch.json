{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "python": "C:/Users/dpanc/miniconda3/envs/cv-architect/python.exe",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Backend: Background Worker",
      "type": "debugpy",
      "request": "launch",
      "python": "C:/Users/dpanc/miniconda3/envs/cv-architect/python.exe",
      "program": "${workspaceFolder}/backend/app/core/worker.py",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Frontend: Debug (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "Start Frontend (Angular)"
    },
    {
      "name": "Frontend: Attach (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Debug",
      "configurations": [
        "Backend: Debug (FastAPI)",
        "Backend: Background Worker",
        "Frontend: Attach (Chrome)"
      ],
      "preLaunchTask": "Start Frontend (Angular)"
    },
    {
      "name": "Full Stack: Run",
      "configurations": [
        "Frontend: Attach (Chrome)"
      ],
      "preLaunchTask": "Start Full Stack"
    }
  ]
}
